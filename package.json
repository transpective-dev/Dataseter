    "commander": "^13.1.0",
    "conf": "^13.0.2",
    "fs-extra": "^11.3.0",
    "ink": "^5.1.0",
    "ink-link": "^5.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.24.2",
    "@iconoir/vue": "^7.11.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^17.3.1",
    "epubjs": "^0.5.0-alpha.3",
    "node-llama-cpp": "^3.18.1",
    "openai": "^6.31.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "tiktoken": "^1.0.22"
