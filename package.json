    "@types/react": "^18.3.12",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "@types/adm-zip": "^0.5.8",
    "@types/cli-progress": "^3.11.6",
    "@types/commander": "^2.12.0",
    "@types/pdf-parse": "^1.1.5"
  },
  "overrides": {
    "@inkjs/ui": {
      "ink": "$ink"
    },
    "ink-link": {
      "ink": "$ink"
